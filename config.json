{
  "service": {
    "name": "Pinterest Pin Generator",
    "version": "2.2.0",
    "port": 3001
  },
  "pinterest": {
    "width": 1000,
    "height": 2000,
    "aspectRatio": "1:2"
  },
  "defaults": {
    "textOptions": {
      "fontSize": 48,
      "fontFamily": "Montserrat",
      "fontWeight": "700",
      "textColor": "#FFFFFF",
      "backgroundColor": "rgba(0, 0, 0, 0.7)",
      "backgroundStrokeTopColor": "#000000",
      "backgroundStrokeTopWidth": 0,
      "backgroundStrokeBottomColor": "#000000",
      "backgroundStrokeBottomWidth": 0,
      "backgroundStrokeLeftWidth": 0,
      "backgroundStrokeRightWidth": 0,
      "paddingTop": 20,
      "paddingBottom": 20,
      "strokeColor": "#000000",
      "strokeWidth": 2
    },
    "titleBand": {
      "textOptions": {
        "fontSize": 36,
        "fontFamily": "Montserrat",
        "fontWeight": "700",
        "textColor": "#FFFFFF",
        "backgroundColor": "#E60023",
        "paddingTop": 20,
        "paddingBottom": 20,
        "paddingLeft": 30,
        "paddingRight": 30,
        "align": "center"
      }
    },
    "topTags": [
      {
        "text": "RECIPE",
        "fontFamily": "Montserrat",
        "fontWeight": "700",
        "fontSize": 18,
        "textColor": "#FFFFFF",
        "backgroundColor": "#E60023",
        "paddingTop": 8,
        "paddingBottom": 8,
        "paddingLeft": 16,
        "paddingRight": 16,
        "borderRadius": 6,
        "position": { "x": 24, "y": 24 }
      }
    ]
  },
  "limits": {
    "maxTextLength": 150,
    "minFontSize": 16,
    "maxFontSize": 120
