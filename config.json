  "availableFonts": [
    { "name": "Montserrat", "weights": ["400", "700"], "type": "sans-serif" },
    { "name": "Playfair Display", "weights": ["400", "700"], "type": "serif" },
    { "name": "Lato", "weights": ["400", "700"], "type": "sans-serif" },
    { "name": "Open Sans", "weights": ["400", "700"], "type": "sans-serif" },
    { "name": "Roboto", "weights": ["400", "700"], "type": "sans-serif" },
    { "name": "Merriweather", "weights": ["400"], "type": "serif" },
    { "name": "Geom", "weights": ["400", "700", "900"], "type": "sans-serif" },
    { "name": "Luckiest Guy", "weights": ["400"], "type": "display" },
    { "name": "Bebas Neue", "weights": ["400"], "type": "display" },
    { "name": "Yellowtail", "weights": ["400"], "type": "script" },
    { "name": "DM Serif Display", "weights": ["400"], "type": "display" }
